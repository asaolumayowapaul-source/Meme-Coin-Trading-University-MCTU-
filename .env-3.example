# ── MEME MASTERY ACADEMY — Environment Variables ──
# Copy this file to .env and fill in all values

# ── TELEGRAM ──────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your personal Telegram ID (get from @userinfobot)
ADMIN_TELEGRAM_ID=your_telegram_id_here

# Single private course channel ID (negative number e.g. -1001234567890)
# Get it by forwarding a channel message to @JsonDumpBot
CHANNEL_ID=-1001234567890

# ── SERVER ────────────────────────────────────────
PORT=3000

# ── PAYSTACK ──────────────────────────────────────
# From Paystack dashboard → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_live_your_key_here
# Set webhook URL in Paystack to: https://your-railway-url.up.railway.app/payment-webhook

# ── WHATSAPP (Meta Cloud API) ─────────────────────
WHATSAPP_API_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here

# Single WhatsApp community group invite link
WHATSAPP_GROUP_LINK=https://chat.whatsapp.com/REPLACE_ME
